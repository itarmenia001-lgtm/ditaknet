# DitakNet public website / WebStile environment.
# Copy to WebStile/.env and replace all change-me values before production.

DATABASE_URL="file:./dev.db"
NEXTAUTH_SECRET="change-me-generate-a-random-32-byte-secret"
NEXTAUTH_URL="https://ditaknet.com"

ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-me-use-a-strong-private-password"
ADMIN_NAME="DitakNet Admin"

APP_NAME="DitakNet"
APP_DISPLAY_NAME="DitakNet"
APP_BRAND_NAME="DitakNet"
APP_BRAND_NAME_HY="DitakNet"
APP_SUPPORT_EMAIL=""
APP_SUPPORT_PHONE=""
APP_SUPPORT_TELEGRAM=""
APP_SUPPORT_URL=""
APP_DOCUMENTATION_URL=""
NEXT_PUBLIC_DEFAULT_LOCALE="hy"

SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""

# Optional deployment values for Cloudflare/remote monitoring infrastructure.
# Keep tunnel tokens and API tokens only on the server, never in client code.
PUBLIC_DOMAIN="ditaknet.com"
CLOUDFLARE_TUNNEL_TOKEN=""
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_ZONE_ID=""
